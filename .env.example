# ── Tuya Cloud API (platform.tuya.com → your cloud project → Overview) ──────
# Access ID / Client ID
NUXT_TUYA_CLIENT_ID=
# Access Secret / Client Secret  ⚠️ keep secret — never commit the real .env
NUXT_TUYA_CLIENT_SECRET=
# Data center: in | eu | us | cn — leave empty to auto-detect
NUXT_TUYA_REGION=

# ── Access control (used from Phase 2 onward) ────────────────────────────────
# Comma-separated IPs or CIDR ranges that skip the PIN page, e.g. 39.50.0.0/16,119.155.1.2
NUXT_AUTH_ALLOWED_IPS=
# The PIN for everyone else
NUXT_AUTH_APP_PIN=
# Long random string for signing session cookies (e.g. `openssl rand -hex 32`)
NUXT_AUTH_SESSION_SECRET=
