# ── Tuya Cloud API (platform.tuya.com → your cloud project → Overview) ──────
# Access ID / Client ID
NUXT_TUYA_CLIENT_ID=
# Access Secret / Client Secret  ⚠️ keep secret — never commit the real .env
NUXT_TUYA_CLIENT_SECRET=
# Data center: in | eu | us | cn — leave empty to auto-detect
NUXT_TUYA_REGION=

# ── Access control ───────────────────────────────────────────────────────────
# Auth is enforced only when BOTH APP_PIN and SESSION_SECRET are set.
# Comma-separated IPs or CIDR ranges that skip the PIN page, e.g. 39.50.0.0/16,119.155.1.2
NUXT_AUTH_ALLOWED_IPS=
# The PIN everyone else must enter
NUXT_AUTH_APP_PIN=
# Long random string for signing session cookies (e.g. `openssl rand -hex 32`)
NUXT_AUTH_SESSION_SECRET=

# ── Machine-to-machine ───────────────────────────────────────────────────────
# Shared secret for /api/admin/* (external cron) and /api/ingest (homelab relay)
# e.g. `openssl rand -hex 32`
NUXT_INGEST_SECRET=

# ── Production database (Vercel only — local dev uses .data/db/sqlite.db) ────
# Injected automatically by the Vercel↔Turso integration:
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# ── Bill scraper ─────────────────────────────────────────────────────────────
# 14-digit IESCO reference number (top of any bill) for the PITC scraper
NUXT_BILL_REFERENCE_NO=
